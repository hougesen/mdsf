{
  "$schema": "../tool.schema.json",
  "binary": "superhtml",
  "categories": ["formatter"],
  "commands": {
    "check": {
      "arguments": ["check", "$PATH"],
      "tests": []
    },
    "fmt": {
      "arguments": ["fmt", "$PATH"],
      "tests": [
        {
          "disabled": true,
          "language": "html",
          "test_input": "<div>\n                    <p>\n                    Mads was here\n                    </p>\n        </div>",
          "test_output": "<div>\n\t<p>\n\t\tMads was here\n\t</p>\n</div>"
        }
      ]
    }
  },
  "description": "HTML Validator, Formatter, LSP, and Templating Language Library",
  "homepage": "https://github.com/kristoff-it/superhtml",
  "languages": ["html"],
  "packages": {
    "brew": {
      "package": "superhtml"
    },
    "mise": {
      "package": "superhtml"
    }
  }
}
